FROM python:3.12-slim

ARG BPV_EXTRAS=postgres,data

WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY pyproject.toml ./
COPY app ./app
COPY shared ./shared
COPY alembic.ini ./
COPY alembic ./alembic

RUN python -m pip install --upgrade pip && python -m pip install ".[${BPV_EXTRAS}]"

CMD ["beauty-product-verifier", "--help"]
