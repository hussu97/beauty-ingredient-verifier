# Backend
BPV_APP_NAME=Beauty Product Verifier
BPV_ENV=local
BPV_DATABASE_URL=sqlite:///./storage/beauty_product_verifier.sqlite3
BPV_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
BPV_STORAGE_DIR=./storage
BPV_AUTO_CREATE_TABLES=true
BPV_BOOTSTRAP_DEMO_DATA=true
BPV_OPEN_BEAUTY_FACTS_USER_AGENT=BeautyProductVerifier/0.1 (local-dev@example.com)
BPV_ENABLE_LIVE_OPEN_BEAUTY_FACTS_LOOKUP=true
BPV_ENABLE_OPTIONAL_ML=false
BPV_ENABLE_SQLITE_VEC=true
BPV_OCR_LANGUAGE=en
BPV_IMAGE_EMBEDDING_MODEL=sentence-transformers/clip-ViT-B-32
BPV_IMAGE_DOWNLOAD_TIMEOUT_SECONDS=20
BPV_SYNC_LOCAL_DATABASE_URL=sqlite:///./storage/beauty_product_verifier.sqlite3
BPV_SYNC_PROD_DATABASE_URL=postgresql+psycopg://bpv:change-me@127.0.0.1:5432/beauty_product_verifier
BPV_SYNC_TABLES=all
BPV_SYNC_BATCH_SIZE=500
BPV_SYNC_STRATEGY=auto
BPV_SYNC_TRUST_TARGET_WATERMARK=false
BPV_EWG_ATTRIBUTION_TEXT=Contains information from EWG Skin Deep.
BPV_EWG_USER_AGENT=BeautyProductVerifier/0.1 (local-dev@example.com)

# Production Docker Compose / deploy
BPV_API_IMAGE=ghcr.io/owner/beauty-product-verifier/api:latest
BPV_POSTGRES_DB=beauty_product_verifier
BPV_POSTGRES_USER=bpv
BPV_POSTGRES_PASSWORD=change-me
BPV_POSTGRES_DATA_DIR=/opt/bpv/postgres-data/pgdata
API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
