# Backend
BPV_APP_NAME=Beauty Product Verifier
BPV_ENV=local
BPV_DATABASE_URL=sqlite:///./storage/beauty_product_verifier.sqlite3
BPV_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
BPV_STORAGE_DIR=./storage
BPV_AUTO_CREATE_TABLES=true
BPV_BOOTSTRAP_DEMO_DATA=true
BPV_OPEN_BEAUTY_FACTS_USER_AGENT=BeautyProductVerifier/0.1 (local-dev@example.com)
BPV_ENABLE_LIVE_OPEN_BEAUTY_FACTS_LOOKUP=true
BPV_ENABLE_OPTIONAL_ML=false
BPV_ENABLE_SQLITE_VEC=true
BPV_OCR_LANGUAGE=en
BPV_IMAGE_EMBEDDING_MODEL=sentence-transformers/clip-ViT-B-32
BPV_IMAGE_DOWNLOAD_TIMEOUT_SECONDS=20

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
